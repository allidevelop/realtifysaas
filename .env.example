# ──────────────────────────────────────────────────────────────
# .env.example — скопировать в .env (ТЗ §17). Секреты не коммитить.
# ──────────────────────────────────────────────────────────────

# Postgres / Redis
# Логин/пароль/имя БД должны совпадать с docker-compose.yml
POSTGRES_USER=geo
POSTGRES_PASSWORD=geo_local_pass
POSTGRES_DB=geo
# Хост-порт 5433 (контейнер на 5433:5432) — чтобы не конфликтовать с локально
# установленным PostgreSQL на 5432. См. DECISIONS.md.
DATABASE_URL=postgres://geo:geo_local_pass@localhost:5433/geo
PG_GIS_SCHEMA=gis
REDIS_URL=redis://localhost:6379

# Payload / Next
PAYLOAD_SECRET=change_me_dev_secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PREVIEW_SECRET=change_me_preview

# Engine
ENGINE_BASE_URL=http://localhost:8000
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Telegram (этап 4)
TELEGRAM_BOT_TOKEN=

# Платежи / биллинг (этап 5; боевые ключи только в prod)
PAYMENTS_PROVIDER=mock              # mock | monobank
WEBHOOK_BASE_URL=http://localhost:3000   # публичный базовый URL для webHookUrl (в dev — туннель для реального Monobank)
MONOBANK_TOKEN=
MONOBANK_API_BASE=https://api.monobank.ua
MOCK_WEBHOOK_SECRET=mock_dev_secret
# Реквизиты продавца для счёта/акта (безнал)
SELLER_NAME=
SELLER_EDRPOU=
SELLER_IBAN=
SELLER_VAT=
# ПриватБанк/LiqPay (второй адаптер, позже)
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
WFP_MERCHANT=
WFP_SECRET=

# Источники данных (этап 0.5/3; заполняется по выбранному источнику)
DATA_SOURCE_API_KEY=
