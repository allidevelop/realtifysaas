# .env.prod.example — ОРИЕНТИР для прод-.env (значения заполняются на сервере, НЕ в репо).
# Отличия от dev: боевые ключи, https-домен, нативные порты БД/Redis.

# Postgres / Redis (на проде обычно нативные, стандартные порты)
DATABASE_URL=postgres://geo:STRONG_PASS@localhost:5432/geo
PG_GIS_SCHEMA=gis
REDIS_URL=redis://localhost:6379

# Payload / Next
PAYLOAD_SECRET=<длинный_случайный_секрет>
NEXT_PUBLIC_SITE_URL=https://realtify.example.com
PREVIEW_SECRET=<секрет>

# Engine
ENGINE_BASE_URL=http://127.0.0.1:8000
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Telegram (боевой токен бота)
TELEGRAM_BOT_TOKEN=<токен>

# Платежи — БОЕВОЙ режим
PAYMENTS_PROVIDER=monobank
WEBHOOK_BASE_URL=https://realtify.example.com
MONOBANK_TOKEN=<боевой_токен_мерчанта>
MONOBANK_API_BASE=https://api.monobank.ua
CRON_SECRET=<секрет_для_/cron/renewals>   # вызывать по cron: GET /cron/renewals?secret=...
# Реквизиты продавца (счёт/акт)
SELLER_NAME=<ФОП/ТОВ>
SELLER_EDRPOU=<ЄДРПОУ>
SELLER_IBAN=<IBAN>
SELLER_VAT=

# ETL / OLX (боевые ключи партнёрского доступа)
ETL_TRIGGER_SECRET=<секрет>
OLX_CLIENT_ID=<client_id>
OLX_CLIENT_SECRET=<client_secret>
OLX_API_BASE=https://www.olx.ua/api/partner
OLX_TOKEN_URL=https://www.olx.ua/api/open/oauth/token
OLX_AREA_ATTR=total_area
OLX_CATEGORY_MAP={"NNN":["apartment","sale"]}
