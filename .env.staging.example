# .env для STAGING/MVP на сервере (субдомен + SSL, mock-платежи).
# Скопировать в корневой .env на сервере и заполнить значения <...>.
# Боевые ключи платежей сюда НЕ кладём (mock) — настоящий прод см. .env.prod.example.

# --- Развёртывание (читает infra/scripts/deploy-staging.sh) ---
STAGING_DOMAIN=app.realtifysaas.wisecat.site   # субдомен MVP (нужна A-запись на IP сервера)
WEB_PORT=3100                                   # свободный порт web (next start)
ENGINE_PORT=8100                                # свободный порт engine (uvicorn, внутренний)

# --- Postgres+Redis (docker compose) ---
# На сервере порт 5433 часто занят соседним проектом → берём 5434 (и уникальные имена).
POSTGRES_USER=geo
POSTGRES_PASSWORD=<сильный_пароль_БД>
POSTGRES_DB=geo
PG_HOST_PORT=5434
REDIS_HOST_PORT=6380
PG_CONTAINER=realtify_postgres
REDIS_CONTAINER=realtify_redis
DATABASE_URL=postgres://geo:<сильный_пароль_БД>@localhost:5434/geo
REDIS_URL=redis://localhost:6380

# --- Payload / web ---
NODE_ENV=production
# MVP без миграций: форсируем push схемы при старте (на настоящем проде — миграции!).
PAYLOAD_DB_PUSH=true
PAYLOAD_SECRET=<openssl rand -hex 32>
# Админ кабинета Payload (публичный сайт! НЕ оставляй дефолтный пароль).
SEED_ADMIN_EMAIL=<твой_email>
SEED_ADMIN_PASSWORD=<сильный_пароль_админа>
SITE_URL=https://app.realtifysaas.wisecat.site
NEXT_PUBLIC_SITE_URL=https://app.realtifysaas.wisecat.site
ENGINE_BASE_URL=http://127.0.0.1:8100

# --- Платежи (СТЕЙДЖ = mock, без реальных денег) ---
PAYMENTS_PROVIDER=mock
WEBHOOK_BASE_URL=https://app.realtifysaas.wisecat.site
MOCK_WEBHOOK_SECRET=<openssl rand -hex 16>
MONOBANK_TOKEN=
MONOBANK_API_BASE=https://api.monobank.ua
CRON_SECRET=<openssl rand -hex 16>

# --- Реквизиты продавца (для PDF счёта/акта — можно демо на стейдже) ---
SELLER_NAME=Realtify MVP
SELLER_EDRPOU=0000000000
SELLER_IBAN=UA000000000000000000000000000
SELLER_VAT=

# --- ETL / источники данных ---
ETL_TRIGGER_SECRET=<openssl rand -hex 16>
PROZORRO_API_BASE=https://procedure.prozorro.sale/api
PROZORRO_SINCE=
# DOM.RIA — вписать, когда придёт апрув (developers.ria.com); пусто = источник не зовём
DOMRIA_API_KEY=
DOMRIA_STATE_ID=
DOMRIA_SEARCH_GROUPS=
# OLX — канал постинга (не источник данных); ключи опц.
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=

# --- Прочее ---
NOMINATIM_URL=https://nominatim.openstreetmap.org
TELEGRAM_BOT_TOKEN=               # пусто → бот graceful-выходит (на стейдже не обязателен)
