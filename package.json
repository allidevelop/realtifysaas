{
  "name": "realtify-geoanalytics",
  "version": "0.0.0",
  "private": true,
  "description": "Коммерческая геоаналитическая платформа рынка недвижимости (монорепо: web + engine).",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v"
  },
  "devDependencies": {
    "prettier": "3.4.2",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "esbuild", "unrs-resolver"]
  }
}
